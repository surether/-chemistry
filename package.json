{
  "name": "chemistry-dragon-reaction-web",
  "version": "0.1.0",
  "private": true,
  "description": "Browser and PWA version of the Korean chemistry reaction fantasy game.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config vite.config.mjs --host 127.0.0.1 --port 5173",
    "dev:renderer": "vite --config vite.config.mjs --host 127.0.0.1 --port 5173",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsc --noEmit && vite build --config vite.config.mjs",
    "build:web": "tsc --noEmit && vite build --config vite.config.mjs",
    "build:desktop": "tsc --noEmit && vite build --config vite.config.mjs && tsc -p electron/tsconfig.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "node scripts/static-check.mjs",
    "check:browser": "node scripts/pwa-browser-check.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "preview": "vite preview --config vite.config.mjs --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  }
}
